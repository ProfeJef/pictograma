<script>
var CATS = {
  papel:    { e:"📄", label:"Papel",    color:"#3b82f6", bg:"#eff6ff", border:"#bfdbfe", tip:"Periódicos, cartón, cuadernos viejos" },
  plastico: { e:"🧴", label:"Plástico", color:"#f59e0b", bg:"#fffbeb", border:"#fde68a", tip:"Botellas, bolsas, pitillos" },
  organico: { e:"🍌", label:"Orgánico", color:"#10b981", bg:"#f0fdf4", border:"#bbf7d0", tip:"Cáscaras, restos de comida" },
  metal:    { e:"🥫", label:"Metal",    color:"#64748b", bg:"#f8fafc", border:"#e2e8f0", tip:"Latas, tapas, alambres" },
  vidrio:   { e:"🍾", label:"Botella",  color:"#06b6d4", bg:"#ecfeff", border:"#a5f3fc", tip:"Botellas de vidrio, frascos" }
};
var ORI_COLORS = ["#8b5cf6","#ec4899","#f97316","#14b8a6","#a16207"];

var ECO = {
  papel:    ["¡El papel se puede reciclar hasta 7 veces para hacer cuadernos nuevos! 📚","Reciclar una tonelada de papel salva 17 árboles 🌳","El papel reciclado usa 60% menos energía que el nuevo ⚡"],
  plastico: ["¡Una botella plástica puede tardar 500 años en desaparecer! 🐢","Con 5 botellas recicladas se puede hacer una camiseta 👕","Reciclar plástico protege a los peces y tortugas del mar 🐠"],
  organico: ["¡Las cáscaras de fruta se convierten en abono para las plantas! 🌿","Los restos de comida reciclados enriquecen la tierra del jardín 🌱","Con la materia orgánica se puede hacer compost casero 🪱"],
  metal:    ["¡Una lata reciclada ahorra energía para ver 3 horas de dibujos! 📺","El metal se puede reciclar infinitas veces sin perder calidad ♾️","Con latas recicladas se hacen piezas de bicicletas y autos 🚲"],
  vidrio:   ["¡El vidrio se puede reciclar infinitas veces sin perder calidad! ✨","Reciclar vidrio reduce la contaminación del agua 💧","El vidrio reciclado funde a menor temperatura, ¡ahorra energía! 🔥"]
};
var CURIOSIDADES = [
  "¿Sabías que el papel se puede reciclar hasta 7 veces para hacer cuadernos nuevos? 📚",
  "¡Una botella de plástico puede tardar 500 años en desaparecer del planeta! 🐢",
  "¡Reciclar una lata de aluminio ahorra energía para ver 3 horas de dibujos! 📺",
  "¡Las cáscaras de fruta se convierten en abono para que crezcan más flores! 🌸",
  "¡El vidrio nunca pierde calidad, se puede reciclar infinitas veces! 🫙",
  "Si todos reciclan, podemos salvar miles de animales marinos cada año 🐬"
];

var data = {
  items:[], nextId:1,
  origen:"Casa", cat:"papel", qty:1,
  catFiltros:{papel:true,plastico:true,organico:true,metal:true,vidrio:true}
};

// ====== INIT ======
window.addEventListener("DOMContentLoaded", function() {
  buildStats(); buildCatGrid(); buildTips();

  // Tabs
  document.querySelectorAll(".tab").forEach(function(tab) {
    tab.addEventListener("click", function() {
      document.querySelectorAll(".tab").forEach(function(t){ t.classList.remove("active"); });
      document.querySelectorAll(".panel").forEach(function(p){ p.classList.remove("active"); });
      tab.classList.add("active");
      document.getElementById("panel-" + tab.getAttribute("data-tab")).classList.add("active");
    });
  });

  // Origen
  document.getElementById("pill-origen").addEventListener("click", function(e) {
    var pill = e.target.closest(".pill");
    if (!pill) return;
    document.querySelectorAll("#pill-origen .pill").forEach(function(p){ p.classList.remove("on"); });
    pill.classList.add("on");
    data.origen = pill.getAttribute("data-v");
  });

  // Cantidad
  document.getElementById("btn-menos").addEventListener("click", function() {
    data.qty = Math.max(1, data.qty - 1);
    document.getElementById("qty-val").textContent = data.qty;
  });
  document.getElementById("btn-mas").addEventListener("click", function() {
    data.qty = Math.min(20, data.qty + 1);
    document.getElementById("qty-val").textContent = data.qty;
  });

  // Agregar
  document.getElementById("btn-agregar").addEventListener("click", agregarItem);
  document.getElementById("f-nombre").addEventListener("keydown", function(e){ if(e.key==="Enter") agregarItem(); });

  // Pictograma controles
  document.getElementById("p-titulo").addEventListener("input", dibujarPicto);
  document.getElementById("p-simbolo").addEventListener("change", function() {
    document.getElementById("p-custom").style.display = this.value==="custom"?"inline-block":"none";
    dibujarPicto();
  });
  document.getElementById("p-custom").addEventListener("input", dibujarPicto);
  document.getElementById("p-escala").addEventListener("change", dibujarPicto);
  document.getElementById("pf-row").addEventListener("click", function(e) {
    var btn = e.target.closest(".pf-btn");
    if (!btn) return;
    var cat = btn.getAttribute("data-cat");
    data.catFiltros[cat] = !data.catFiltros[cat];
    btn.classList.toggle("active", data.catFiltros[cat]);
    dibujarPicto();
  });

  // Barras controles
  document.getElementById("b-titulo").addEventListener("input", dibujarBarras);
  document.getElementById("b-grupo").addEventListener("change", dibujarBarras);
  document.getElementById("b-orient").addEventListener("change", dibujarBarras);

  // Header buttons
  document.getElementById("btnPrint").addEventListener("click", function(){ window.print(); });
  document.getElementById("btnExport").addEventListener("click", exportarCSV);
  document.getElementById("btnReset").addEventListener("click", function() {
    if (!data.items.length) { toast("⚠️ ¡No hay registros que limpiar!"); return; }
    document.getElementById("modal-overlay").style.display = "flex";
  });

  // Modal
  document.getElementById("modal-cancel").addEventListener("click", function() {
    document.getElementById("modal-overlay").style.display = "none";
  });
  document.getElementById("modal-ok").addEventListener("click", function() {
    document.getElementById("modal-overlay").style.display = "none";
    data.items = [];
    renderTodo();
    toast("🗑️ ¡Diario limpio! Puedes empezar de nuevo 🌱");
  });
  document.getElementById("modal-overlay").addEventListener("click", function(e) {
    if (e.target === this) this.style.display = "none";
  });

  cargarDemo();
  cambiarCuriosidad();
});

// ====== BUILD UI ======
function buildStats() {
  var html = "";
  Object.keys(CATS).forEach(function(k) {
    var c = CATS[k];
    html += '<div class="stat" style="border-color:'+c.color+';color:'+c.color+'">'
      + '<div class="stat-em">'+c.e+'</div>'
      + '<div class="stat-n" id="st-'+k+'">0</div>'
      + '<div class="stat-l">'+c.label+'</div>'
    + '</div>';
  });
  document.getElementById("stats-container").innerHTML = html;
}

function buildCatGrid() {
  var html = "";
  Object.keys(CATS).forEach(function(k) {
    var c = CATS[k];
    html += '<button class="cat-btn '+k+(k==="papel"?" on":"")
      +'" data-v="'+k+'" style="color:'+c.color+';border-color:'+c.border+';background:'+c.bg+'">'
      + '<span class="cat-em">'+c.e+'</span><span>'+c.label+'</span>'
    + '</button>';
  });
  var el = document.getElementById("cat-grid");
  el.innerHTML = html;
  el.addEventListener("click", function(e) {
    var btn = e.target.closest(".cat-btn");
    if (!btn) return;
    document.querySelectorAll(".cat-btn").forEach(function(b){ b.classList.remove("on"); });
    btn.classList.add("on");
    data.cat = btn.getAttribute("data-v");
  });
}

function buildTips() {
  var html = "";
  Object.keys(CATS).forEach(function(k) {
    var c = CATS[k];
    html += '<div class="tip-item" style="background:'+c.bg+';border-color:'+c.border+'">'
      + '<span class="tip-em">'+c.e+'</span>'
      + '<div><div class="tip-name" style="color:'+c.color+'">'+c.label+'</div>'
      + '<div class="tip-desc">'+c.tip+'</div></div>'
    + '</div>';
  });
  document.getElementById("tip-list").innerHTML = html;
}

// ====== AGREGAR ======
function agregarItem() {
  var nombre = document.getElementById("f-nombre").value.trim();
  if (!nombre) { toast("✏️ ¡Escribe el nombre del objeto!"); document.getElementById("f-nombre").focus(); return; }
  data.items.push({ id:data.nextId++, nombre:nombre, cat:data.cat, origen:data.origen, qty:data.qty });
  document.getElementById("f-nombre").value = "";
  data.qty = 1; document.getElementById("qty-val").textContent = "1";
  renderTodo();
  var msgs = ECO[data.cat];
  mostrarEco(CATS[data.cat].e+" "+nombre+" × "+data.items[data.items.length-1].qty, msgs[Math.floor(Math.random()*msgs.length)]);
  cambiarCuriosidad();
}

function renderTodo() {
  renderRegistro(); dibujarPicto(); dibujarBarras(); actualizarStats();
}

// ====== REGISTRO ======
function renderRegistro() {
  var el = document.getElementById("reg-list");
  if (!data.items.length) {
    el.innerHTML = '<div class="empty-state"><div class="big">♻️</div><strong>¡Aún no hay hallazgos!</strong><span style="font-size:.85rem">Ve a "Agregar Residuo" para empezar</span></div>';
    return;
  }
  var html = "";
  for (var i=data.items.length-1; i>=0; i--) {
    var r=data.items[i], c=CATS[r.cat];
    html += '<div class="reg-item"><span class="ri-em">'+c.e+'</span>'
      +'<div class="ri-info"><div class="ri-name">'+esc(r.nombre)+'</div>'
      +'<div class="ri-meta">📍 '+r.origen+' · '+c.label+'</div></div>'
      +'<span class="ri-qty" style="background:'+c.bg+';color:'+c.color+'">×'+r.qty+'</span>'
      +'<button class="ri-del" data-id="'+r.id+'">✕</button>'
    +'</div>';
  }
  el.innerHTML = html;
  el.querySelectorAll(".ri-del").forEach(function(btn) {
    btn.addEventListener("click", function() {
      var id=parseInt(this.getAttribute("data-id"));
      data.items=data.items.filter(function(r){return r.id!==id;});
      renderTodo();
    });
  });
}

// ====== STATS ======
function actualizarStats() {
  var t={papel:0,plastico:0,organico:0,metal:0,vidrio:0};
  data.items.forEach(function(r){ t[r.cat]+=r.qty; });
  Object.keys(t).forEach(function(k){ var el=document.getElementById("st-"+k); if(el) el.textContent=t[k]; });
}

// ====== PICTOGRAMA ======
function getSym(cat) {
  var v=document.getElementById("p-simbolo").value;
  if(v==="none") return CATS[cat].e;
  if(v==="custom") return document.getElementById("p-custom").value||"🌟";
  return v;
}

function dibujarPicto() {
  var box=document.getElementById("p-box");
  var titulo=document.getElementById("p-titulo").value||"Mi Pictograma";
  var escala=parseInt(document.getElementById("p-escala").value)||1;
  if (!data.items.length) { box.innerHTML='<div class="empty-state"><div class="big">📊</div><strong>¡Aquí aparecerá tu pictograma!</strong><span style="font-size:.85rem;color:#a8c8b8">Primero agrega algunos residuos 👆</span></div>'; return; }
  var filtrados=data.items.filter(function(r){return data.catFiltros[r.cat];});
  if (!filtrados.length) { box.innerHTML='<div class="empty-state"><div class="big">🔍</div><strong>Sin datos visibles</strong><span style="font-size:.85rem">Activa alguna categoría arriba</span></div>'; return; }
  var grupos={};
  Object.keys(CATS).forEach(function(k){ if(data.catFiltros[k]) grupos[k]=0; });
  filtrados.forEach(function(r){ grupos[r.cat]=(grupos[r.cat]||0)+r.qty; });
  var filas=Object.keys(grupos).filter(function(k){return grupos[k]>0;}).map(function(k){return{key:k,val:grupos[k]};}).sort(function(a,b){return b.val-a.val;});
  var rows=filas.map(function(f){
    var c=CATS[f.key],sym=getSym(f.key);
    var full=Math.floor(f.val/escala),rest=f.val%escala;
    var syms="";
    for(var i=0;i<full&&i<60;i++) syms+='<span class="p-sym" style="animation-delay:'+(i*0.025).toFixed(3)+'s">'+sym+'</span>';
    if(rest>0&&full<60){var op=Math.max(0.25,rest/escala).toFixed(2);syms+='<span class="p-sym" style="opacity:'+op+';font-size:1rem">'+sym+'</span>';}
    return '<div class="p-row"><div class="p-row-lbl"><span class="p-ldot" style="background:'+c.color+'"></span>'+c.e+' '+c.label+'</div><div class="p-syms">'+syms+'</div><span class="p-cnt">'+f.val+'</span></div>';
  }).join("");
  var leg='<div class="p-legend">'+filas.map(function(f){return '<div class="leg-i"><span>'+getSym(f.key)+'</span><span>'+CATS[f.key].label+'</span></div>';}).join("")+'</div>';
  var total=filtrados.reduce(function(s,r){return s+r.qty;},0);
  var nota=escala>1?'<div class="p-note">Escala: 1 símbolo = '+escala+' objeto(s)</div>':"";
  box.innerHTML='<div class="p-chart-title">'+esc(titulo)+'</div><div class="p-chart-sub">Total: <strong>'+total+'</strong> residuos</div><div class="p-rows">'+rows+'</div>'+leg+nota;
}

// ====== BARRAS ======
function dibujarBarras() {
  var box=document.getElementById("bar-box");
  var titulo=document.getElementById("b-titulo").value||"Gráfico de Barras";
  var grupo=document.getElementById("b-grupo").value;
  var orient=document.getElementById("b-orient").value;
  if (!data.items.length) { box.innerHTML='<div class="empty-state"><div class="big">📈</div><strong>¡El gráfico aparecerá aquí!</strong><span style="font-size:.85rem;color:#a8c8b8">Primero agrega algunos residuos 👆</span></div>'; return; }
  var grupos={},colores={};
  if (grupo==="cat") {
    Object.keys(CATS).forEach(function(k){ grupos[k]=0; colores[k]=CATS[k].color; });
    data.items.forEach(function(r){ grupos[r.cat]+=r.qty; });
  } else {
    var idx=0;
    data.items.forEach(function(r){ if(grupos[r.origen]===undefined){ grupos[r.origen]=0; colores[r.origen]=ORI_COLORS[idx++%ORI_COLORS.length]; } grupos[r.origen]+=r.qty; });
  }
  var filas=Object.keys(grupos).filter(function(k){return grupos[k]>0;}).map(function(k){return{key:k,val:grupos[k],color:colores[k],em:grupo==="cat"?CATS[k].e:"📍",lbl:grupo==="cat"?CATS[k].label:k};}).sort(function(a,b){return b.val-a.val;});
  if (!filas.length) { box.innerHTML='<div class="empty-state"><div class="big">📈</div><strong>Sin datos</strong></div>'; return; }
  var maxVal=Math.max.apply(null,filas.map(function(f){return f.val;}));
  var total=data.items.reduce(function(s,r){return s+r.qty;},0);
  var head='<div class="bar-title">'+esc(titulo)+'</div><div class="bar-sub">Total: <strong>'+total+'</strong> residuos clasificados</div>';

  if (orient==="v") {
    var steps=4,stepVal=Math.ceil(maxVal/steps),ylines="";
    for(var s=1;s<=steps;s++){ var pct=Math.min(100,(s*stepVal/maxVal)*100); ylines+='<div class="y-line" style="bottom:'+pct+'%"><span class="y-lbl">'+(s*stepVal)+'</span></div>'; }
    var bars=filas.map(function(f){
      var h=Math.max(4,Math.round((f.val/maxVal)*100));
      return '<div class="bar-col"><div class="bar-wrap"><div class="bar" style="height:'+h+'%;background:'+f.color+'" title="'+f.lbl+': '+f.val+'"><div class="bar-val-v" style="color:'+f.color+'">'+f.val+'</div></div></div><div class="bar-em">'+f.em+'</div><div class="bar-lbl" style="color:'+f.color+'">'+f.lbl+'</div></div>';
    }).join("");
    box.innerHTML=head+'<div style="position:relative;padding-left:34px"><div class="bar-chart-v" style="position:relative">'+ylines+bars+'</div><div style="text-align:center;font-size:.72rem;font-weight:800;color:#b0ccbc;margin-top:8px">Tipo de residuo</div></div>';
  } else {
    var hbars=filas.map(function(f){
      var w=Math.max(6,Math.round((f.val/maxVal)*100));
      return '<div class="bar-h-row"><div class="bar-h-lbl">'+f.em+' '+f.lbl+'</div><div class="bar-h-track"><div class="bar-h-fill" style="width:'+w+'%;background:'+f.color+'"><span class="bar-h-val">'+f.val+'</span></div></div></div>';
    }).join("");
    box.innerHTML=head+'<div style="margin-top:10px">'+hbars+'</div>';
  }
}

// ====== UTILS ======
function toast(msg) {
  var el=document.getElementById("toast");
  el.textContent=msg; el.classList.add("show");
  setTimeout(function(){el.classList.remove("show");},3000);
}

var ecoTimer=null;
function mostrarEco(added, msg) {
  document.getElementById("eco-added").textContent=added;
  document.getElementById("eco-msg").textContent=msg;
  var pop=document.getElementById("eco-popup");
  pop.style.display="block";
  requestAnimationFrame(function(){ requestAnimationFrame(function(){
    pop.style.opacity="1"; pop.style.transform="translateX(-50%) translateY(0)";
  }); });
  if(ecoTimer) clearTimeout(ecoTimer);
  ecoTimer=setTimeout(function(){
    pop.style.opacity="0"; pop.style.transform="translateX(-50%) translateY(30px)";
    setTimeout(function(){ pop.style.display="none"; },350);
  },4200);
}

function cambiarCuriosidad() {
  var el=document.getElementById("cur-txt");
  if(el) el.textContent=CURIOSIDADES[Math.floor(Math.random()*CURIOSIDADES.length)];
}

function esc(s){ return String(s).replace(/&/g,"&amp;").replace(/</g,"&lt;").replace(/>/g,"&gt;"); }

function exportarCSV() {
  if (!data.items.length) { toast("⚠️ ¡Primero registra algunos residuos!"); return; }
  var BOM="\uFEFF";
  var filas=[["ID","Objeto","Categoría","Dónde","Cantidad"]];
  data.items.forEach(function(r){ filas.push([r.id,r.nombre,CATS[r.cat].label,r.origen,r.qty]); });
  var csv=BOM+filas.map(function(f){return f.map(function(v){return '"'+String(v).replace(/"/g,'""')+'"';}).join(";");}).join("\r\n");
  var a=document.createElement("a");
  a.href=URL.createObjectURL(new Blob([csv],{type:"text/csv;charset=utf-8;"}));
  a.download="mi_diario_reciclaje.csv";
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  setTimeout(function(){ URL.revokeObjectURL(a.href); },1000);
  toast("✅ ¡CSV guardado!");
}

