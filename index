<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🌍 Mi Diario de Reciclaje</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@700;800;900&family=Nunito+Sans:wght@400;600;700&display=swap" rel="stylesheet">
<style>
* { box-sizing:border-box; margin:0; padding:0; }
body { font-family:'Nunito Sans',sans-serif; background:linear-gradient(160deg,#e8f5ee 0%,#f0f9ff 60%,#fff9e8 100%); color:#1a3a2a; min-height:100vh; padding-bottom:50px; }
button { cursor:pointer; border:none; font-family:'Nunito',sans-serif; }
input,select { font-family:'Nunito',sans-serif; }
.app { max-width:1060px; margin:0 auto; padding:16px; }

/* ====== HEADER ====== */
.header { background:#fff; border-radius:28px; padding:18px 24px; display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:14px; box-shadow:0 8px 28px rgba(26,138,74,.14); margin-bottom:20px; border:3px solid #1a8a4a; }
.brand { display:flex; align-items:center; gap:14px; }
.brand-logo { width:58px; height:58px; background:linear-gradient(135deg,#1a8a4a,#22c55e); border-radius:18px; display:flex; align-items:center; justify-content:center; font-size:2rem; box-shadow:0 5px 14px rgba(0,120,60,.28); flex-shrink:0; }
.brand-title { font-family:'Nunito',sans-serif; font-size:1.55rem; font-weight:900; color:#1a8a4a; line-height:1.1; letter-spacing:-.02em; }
.brand-sub { font-size:.88rem; color:#4a7060; font-weight:700; margin-top:3px; }
.header-btns { display:flex; gap:8px; flex-wrap:wrap; }
.hbtn { padding:10px 18px; border-radius:16px; background:#f0f7f4; color:#1a8a4a; font-weight:800; font-size:.85rem; border:2px solid #c8e6d4; transition:all .2s; display:flex; align-items:center; gap:7px; }
.hbtn:hover { background:#1a8a4a; color:#fff; transform:translateY(-2px); border-color:#1a8a4a; }
.hbtn:active { transform:none; }
.hbtn-danger { color:#dc2626; border-color:#fecaca; background:#fef2f2; }
.hbtn-danger:hover { background:#dc2626; color:#fff; border-color:#dc2626; }

/* ====== STATS ====== */
.stats { display:grid; grid-template-columns:repeat(5,1fr); gap:12px; margin-bottom:20px; }
.stat { background:#fff; border-radius:22px; padding:14px 6px 12px; text-align:center; border-bottom:5px solid; transition:transform .22s; box-shadow:0 3px 10px rgba(0,0,0,.06); cursor:default; }
.stat:hover { transform:scale(1.05); }
.stat-em { font-size:2rem; margin-bottom:3px; }
.stat-n { font-family:'Nunito',sans-serif; font-size:1.9rem; font-weight:900; line-height:1; }
.stat-l { font-size:.75rem; font-weight:900; text-transform:uppercase; letter-spacing:.04em; margin-top:4px; opacity:.75; }

/* ====== TABS ====== */
.tabs { display:flex; gap:0; background:#e0f0e8; border-radius:18px; padding:5px; margin-bottom:20px; }
.tab { flex:1; padding:10px 8px; border-radius:14px; background:transparent; font-size:.88rem; font-weight:900; color:#4a7060; transition:all .2s; display:flex; align-items:center; justify-content:center; gap:7px; border:none; }
.tab.active { background:#fff; color:#1a8a4a; box-shadow:0 4px 12px rgba(0,100,50,.13); }
.tab:hover:not(.active) { background:rgba(255,255,255,.55); }
.panel { display:none; }
.panel.active { display:block; }

/* ====== GRID ====== */
.grid2 { display:grid; grid-template-columns:1.15fr .85fr; gap:20px; }
.full { grid-column:1/-1; }
@media(max-width:820px){ .grid2{grid-template-columns:1fr;} .stats{grid-template-columns:repeat(3,1fr);} .tabs{flex-wrap:wrap;} }

/* ====== CARD ====== */
.card { background:#fff; border-radius:26px; box-shadow:0 5px 16px rgba(0,0,0,.07); overflow:hidden; border:2.5px solid #daeee3; }
.card-head { background:#f8fdf9; border-bottom:2.5px solid #daeee3; padding:14px 20px; display:flex; align-items:center; gap:10px; }
.card-ico { width:36px; height:36px; border-radius:12px; display:flex; align-items:center; justify-content:center; font-size:1.15rem; flex-shrink:0; }
.card-title { font-family:'Nunito',sans-serif; font-size:1.05rem; font-weight:900; color:#1a3a2a; }
.card-body { padding:20px; }

/* ====== FORMULARIO ====== */
.field { margin-bottom:18px; }
.label { font-family:'Nunito',sans-serif; font-size:.95rem; font-weight:900; display:block; color:#1a3a2a; margin-bottom:8px; display:flex; align-items:center; gap:6px; }
.pill-row { display:flex; flex-wrap:wrap; gap:8px; }
.pill { padding:9px 16px; border-radius:14px; background:#f0f7f4; font-size:.88rem; font-weight:800; color:#4a7060; border:2.5px solid #c8e6d4; transition:all .18s; display:flex; align-items:center; gap:5px; }
.pill.on { background:#1a8a4a; color:#fff; border-color:#1a8a4a; box-shadow:0 4px 10px rgba(0,120,60,.22); transform:scale(1.04); }

.input-text { width:100%; padding:13px 15px; border-radius:14px; border:2.5px solid #c8e6d4; font-size:1rem; font-weight:700; color:#1a3a2a; background:#f8fdf9; outline:none; transition:all .18s; }
.input-text:focus { border-color:#1a8a4a; background:#fafffb; box-shadow:0 0 0 4px #c8ecd8; }

.cat-grid { display:grid; grid-template-columns:repeat(5,1fr); gap:9px; }
.cat-btn { padding:11px 4px; border-radius:16px; font-size:.74rem; font-weight:900; opacity:.45; transition:all .2s; display:flex; flex-direction:column; align-items:center; gap:5px; border:2.5px solid transparent; background:#fff; color:inherit; }
.cat-btn .cat-em { font-size:1.65rem; }
.cat-btn.on { opacity:1; transform:translateY(-4px); box-shadow:0 6px 14px rgba(0,0,0,.12); }

.qty-row { display:flex; align-items:center; gap:14px; }
.qty-btn { width:46px; height:46px; border-radius:16px; background:linear-gradient(135deg,#1a8a4a,#22c55e); color:#fff; font-size:1.5rem; font-weight:900; box-shadow:0 4px 10px rgba(0,120,60,.22); transition:transform .15s; }
.qty-btn:hover { transform:scale(1.08); }
.qty-btn:active { transform:scale(.95); }
.qty-val { font-family:'Nunito',sans-serif; font-size:1.6rem; font-weight:900; width:54px; text-align:center; color:#1a3a2a; }

.add-btn { width:100%; padding:15px; border-radius:20px; background:linear-gradient(135deg,#1a8a4a,#22c55e); color:#fff; font-size:1.05rem; font-weight:900; box-shadow:0 7px 0 #126b39; transition:all .12s; display:flex; align-items:center; justify-content:center; gap:8px; margin-top:4px; }
.add-btn:active { transform:translateY(4px); box-shadow:0 3px 0 #126b39; }
.add-btn:hover { filter:brightness(1.06); }

/* ====== CARD AYUDA ====== */
.tip-item { display:flex; align-items:center; gap:11px; padding:11px 13px; border-radius:14px; border:2.5px solid; margin-bottom:9px; }
.tip-em { font-size:1.7rem; }
.tip-name { font-size:.88rem; font-weight:900; }
.tip-desc { font-size:.76rem; color:#4a7060; font-weight:700; margin-top:1px; }

/* ====== REGISTRO ====== */
.reg-list { display:flex; flex-direction:column; gap:8px; max-height:380px; overflow-y:auto; }
.reg-list::-webkit-scrollbar { width:5px; }
.reg-list::-webkit-scrollbar-thumb { background:#c8e6d4; border-radius:4px; }
.reg-item { display:flex; align-items:center; gap:11px; padding:12px 14px; border-radius:16px; background:#f9fffb; border:2px solid #daeee3; animation:fadeIn .22s ease; }
@keyframes fadeIn{from{opacity:0;transform:translateX(-8px)}to{opacity:1;transform:none}}
.ri-em { font-size:1.45rem; flex-shrink:0; }
.ri-info { flex:1; min-width:0; }
.ri-name { font-size:.9rem; font-weight:800; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
.ri-meta { font-size:.75rem; color:#6b8e7d; font-weight:700; }
.ri-qty { font-size:.8rem; font-weight:900; padding:4px 11px; border-radius:999px; flex-shrink:0; }
.ri-del { width:28px; height:28px; border-radius:999px; background:transparent; color:#c9d8ce; font-size:.85rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; transition:all .15s; border:none; }
.ri-del:hover { background:#fee2e2; color:#dc2626; }
.empty-state { text-align:center; padding:42px 18px; color:#a8d8b8; font-weight:800; display:flex; flex-direction:column; align-items:center; gap:10px; }
.empty-state .big { font-size:3rem; opacity:.3; }

/* ====== PICTOGRAMA ====== */
.p-ctrl { display:flex; flex-wrap:wrap; gap:10px; align-items:center; background:#e8f5ee; border-radius:14px; padding:11px 15px; margin-bottom:12px; }
.p-ctrl-g { display:flex; align-items:center; gap:6px; }
.p-lbl { font-size:.78rem; font-weight:900; color:#4a7060; white-space:nowrap; }
.p-sel { padding:6px 10px; border-radius:9px; border:2px solid #c8e6d4; background:#fff; font-size:.78rem; font-weight:800; color:#1a3a2a; }
.p-tin { padding:6px 12px; border-radius:9px; border:2px solid #c8e6d4; background:#fff; font-size:.9rem; font-weight:900; color:#1a3a2a; font-family:'Nunito',sans-serif; min-width:175px; }
.pf-row { display:flex; flex-wrap:wrap; gap:6px; margin-bottom:12px; align-items:center; }
.pf-btn { display:flex; align-items:center; gap:5px; padding:5px 13px; border-radius:999px; border:2.5px solid transparent; font-size:.76rem; font-weight:900; cursor:pointer; transition:all .15s; opacity:.4; }
.pf-btn.active { opacity:1; box-shadow:0 2px 8px rgba(0,0,0,.09); }
.pf-btn.papel    { background:#eff6ff; color:#3b82f6; border-color:#bfdbfe; }
.pf-btn.plastico { background:#fffbeb; color:#d97706; border-color:#fde68a; }
.pf-btn.organico { background:#f0fdf4; color:#16a34a; border-color:#bbf7d0; }
.pf-btn.metal    { background:#f8fafc; color:#64748b; border-color:#e2e8f0; }
.pf-btn.vidrio   { background:#ecfeff; color:#0891b2; border-color:#a5f3fc; }
.pf-btn.active.papel    { background:#dbeafe; }
.pf-btn.active.plastico { background:#fef3c7; }
.pf-btn.active.organico { background:#dcfce7; }
.pf-btn.active.metal    { background:#e2e8f0; }
.pf-btn.active.vidrio   { background:#cffafe; }

.p-box { background:#f8fdf9; border-radius:16px; border:2.5px dashed #c8e6d4; padding:22px; min-height:120px; }
.p-chart-title { font-family:'Nunito',sans-serif; font-size:1.2rem; font-weight:900; text-align:center; color:#1a8a4a; margin-bottom:4px; }
.p-chart-sub { font-size:.78rem; text-align:center; color:#4a7060; font-weight:700; margin-bottom:18px; }
.p-rows { display:flex; flex-direction:column; gap:14px; }
.p-row { display:flex; align-items:center; gap:10px; padding-bottom:10px; border-bottom:1.5px solid #f0f7f4; }
.p-row:last-child { border-bottom:none; }
.p-row-lbl { display:flex; align-items:center; gap:7px; min-width:118px; max-width:118px; font-size:.84rem; font-weight:900; }
.p-ldot { width:9px; height:9px; border-radius:50%; flex-shrink:0; }
.p-syms { display:flex; flex-wrap:wrap; gap:3px; flex:1; align-items:center; }
.p-sym { font-size:1.6rem; display:inline-block; animation:pop .22s cubic-bezier(.175,.885,.32,1.28) both; cursor:default; }
.p-sym:hover { transform:scale(1.35); }
@keyframes pop{from{transform:scale(0)}to{transform:scale(1)}}
.p-cnt { font-family:'Nunito',sans-serif; font-size:1rem; font-weight:900; color:#1a8a4a; margin-left:4px; }
.p-legend { display:flex; flex-wrap:wrap; gap:12px; justify-content:center; margin-top:16px; padding-top:13px; border-top:1.5px solid #daeee3; }
.leg-i { display:flex; align-items:center; gap:5px; font-size:.78rem; font-weight:900; }
.p-note { font-size:.72rem; color:#a8c8b8; text-align:right; margin-top:8px; font-style:italic; }

/* ====== GRÁFICO DE BARRAS ====== */
.bar-ctrl { display:flex; flex-wrap:wrap; gap:10px; align-items:center; background:#e8f5ee; border-radius:14px; padding:11px 15px; margin-bottom:14px; }
.bar-box { background:#f8fdf9; border-radius:16px; border:2.5px solid #daeee3; padding:22px; }
.bar-title { font-family:'Nunito',sans-serif; font-size:1.2rem; font-weight:900; text-align:center; color:#1a8a4a; margin-bottom:4px; }
.bar-sub { font-size:.78rem; text-align:center; color:#4a7060; font-weight:700; margin-bottom:20px; }
/* Barras verticales */
.bar-chart-v { display:flex; align-items:flex-end; justify-content:center; gap:16px; height:230px; padding-top:28px; border-bottom:3px solid #c8e6d4; border-left:3px solid #c8e6d4; position:relative; margin:0 10px 0 32px; }
.bar-col { display:flex; flex-direction:column; align-items:center; justify-content:flex-end; flex:1; max-width:90px; height:100%; }
.bar-wrap { display:flex; flex-direction:column; align-items:center; justify-content:flex-end; width:100%; height:100%; }
.bar { width:100%; border-radius:12px 12px 0 0; position:relative; min-height:3px; transition:height .6s cubic-bezier(.34,1.56,.64,1); box-shadow:0 5px 14px rgba(0,0,0,.12); cursor:default; }
.bar:hover { filter:brightness(1.08); }
.bar-val-v { position:absolute; top:-26px; width:100%; text-align:center; font-family:'Nunito',sans-serif; font-size:1rem; font-weight:900; }
.bar-em { font-size:1.5rem; margin-top:7px; }
.bar-lbl { font-size:.76rem; font-weight:900; text-align:center; }
/* Y lines */
.y-line { position:absolute; left:0; right:0; border-top:1.5px dashed #daeee3; }
.y-lbl { position:absolute; left:-30px; font-size:.68rem; color:#b0ccbc; font-weight:800; transform:translateY(50%); }
/* Barras horizontales */
.bar-h-row { display:flex; align-items:center; gap:11px; margin-bottom:11px; }
.bar-h-lbl { min-width:86px; text-align:right; font-size:.82rem; font-weight:900; display:flex; align-items:center; justify-content:flex-end; gap:5px; }
.bar-h-track { flex:1; height:38px; background:#f0f7f4; border-radius:999px; overflow:hidden; }
.bar-h-fill { height:100%; border-radius:999px; display:flex; align-items:center; justify-content:flex-end; padding-right:12px; transition:width .6s cubic-bezier(.34,1.56,.64,1); min-width:40px; }
.bar-h-val { color:#fff; font-family:'Nunito',sans-serif; font-size:.9rem; font-weight:900; text-shadow:0 1px 3px rgba(0,0,0,.25); }

/* ====== CURIOSIDAD ====== */
.curiosidad { background:#fff; border-radius:18px; padding:14px 18px; border:2.5px solid #fbbf24; display:flex; align-items:center; gap:14px; margin-top:16px; }
.cur-ico { font-size:2rem; flex-shrink:0; }
.cur-txt { font-size:.88rem; font-weight:800; color:#4a7060; line-height:1.45; font-family:'Nunito Sans',sans-serif; }

/* ====== MODAL ====== */
#modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.48); z-index:10000; align-items:center; justify-content:center; }
.modal-box { background:#fff; border-radius:26px; padding:30px 28px 24px; max-width:340px; width:92%; box-shadow:0 18px 50px rgba(0,0,0,.28); animation:pop .25s ease both; text-align:center; }
.modal-ico { font-size:2.4rem; margin-bottom:10px; }
.modal-title { font-family:'Nunito',sans-serif; font-size:1.15rem; font-weight:900; color:#1a3a2a; margin-bottom:8px; }
.modal-body { font-size:.88rem; color:#4a7060; font-weight:700; margin-bottom:22px; line-height:1.5; font-family:'Nunito Sans',sans-serif; }
.modal-btns { display:flex; gap:10px; justify-content:center; }
.modal-cancel { padding:10px 22px; border-radius:999px; border:2.5px solid #c8e6d4; background:#fff; color:#4a7060; font-weight:900; font-size:.88rem; cursor:pointer; font-family:'Nunito',sans-serif; }
.modal-ok { padding:10px 22px; border-radius:999px; background:#dc2626; color:#fff; font-weight:900; font-size:.88rem; cursor:pointer; font-family:'Nunito',sans-serif; box-shadow:0 4px 12px rgba(220,38,38,.3); border:none; }

/* ====== ECO POPUP ====== */
#eco-popup { display:none; position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(30px); z-index:9998; max-width:440px; width:92%; opacity:0; transition:all .32s ease; }
.eco-inner { background:#fff; border-radius:20px; padding:15px 20px; box-shadow:0 10px 36px rgba(0,120,60,.18); border:2.5px solid #c8ecd8; display:flex; gap:14px; align-items:flex-start; }
.eco-added { font-size:.95rem; font-weight:900; color:#1a8a4a; white-space:nowrap; padding-top:1px; }
.eco-divider { width:2px; background:#c8ecd8; border-radius:4px; align-self:stretch; flex-shrink:0; }
.eco-right { flex:1; }
.eco-tag { font-size:.68rem; font-weight:900; color:#1a8a4a; text-transform:uppercase; letter-spacing:.06em; margin-bottom:3px; }
.eco-msg { font-size:.88rem; font-weight:700; color:#1a3a2a; font-family:'Nunito Sans',sans-serif; line-height:1.45; }

/* ====== TOAST ====== */
#toast { position:fixed; top:22px; right:22px; background:#1a8a4a; color:#fff; padding:12px 22px; border-radius:18px; font-family:'Nunito',sans-serif; font-weight:900; font-size:.9rem; box-shadow:0 10px 28px rgba(0,80,30,.28); transform:translateX(200%); transition:.4s cubic-bezier(.34,1.56,.64,1); z-index:10001; }
#toast.show { transform:translateX(0); }

@media print {
  * { -webkit-print-color-adjust: exact !important; print-color-adjust: exact !important; color-adjust: exact !important; }
  body { background:#fff; }
  .header-btns,.tabs,.entry-panel,.reg-panel,.p-ctrl,.pf-row,.bar-ctrl,.curiosidad { display:none!important; }
  .grid2 { grid-template-columns:1fr; }
  .full { grid-column:1; }
  .card { box-shadow:none; border:2px solid #ddd; }
  .bar, .bar-h-fill { print-color-adjust:exact; -webkit-print-color-adjust:exact; }
  .p-sym { print-color-adjust:exact; }
}
</style>
</head>
<body>
<div id="toast"></div>

<!-- ====== MODAL ====== -->
<div id="modal-overlay" style="display:none">
  <div class="modal-box">
    <div class="modal-ico">🗑️</div>
    <div class="modal-title">¿Borrar todo el progreso?</div>
    <div class="modal-body">Si limpias tu diario perderás todos los residuos registrados hoy. ¿Estás seguro, Guardián?</div>
    <div class="modal-btns">
      <button class="modal-cancel" id="modal-cancel">Cancelar</button>
      <button class="modal-ok" id="modal-ok">Sí, limpiar</button>
    </div>
  </div>
</div>

<!-- ====== ECO POPUP ====== -->
<div id="eco-popup">
  <div class="eco-inner">
    <div class="eco-added" id="eco-added"></div>
    <div class="eco-divider"></div>
    <div class="eco-right">
      <div class="eco-tag">💡 ¿Sabías que…?</div>
      <div class="eco-msg" id="eco-msg"></div>
    </div>
  </div>
</div>

<div class="app">

<!-- HEADER -->
<div class="header">
  <div class="brand">
    <div class="brand-logo">♻️</div>
    <div>
      <div class="brand-title">🌍 Mi Diario de Reciclaje</div>
      <div class="brand-sub">¡Cuento mis residuos y ayudo al planeta! 🌱</div>
    </div>
  </div>
  <div class="header-btns">
    <button class="hbtn" id="btnPrint">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
      Imprimir
    </button>
    <button class="hbtn" id="btnExport">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
      Guardar CSV
    </button>
    <button class="hbtn hbtn-danger" id="btnReset">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
      Borrar Todo
    </button>
  </div>
</div>

<!-- STATS -->
<div class="stats" id="stats-container"></div>

<!-- TABS -->
<div class="tabs">
  <button class="tab active" data-tab="entrada">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="16"/><line x1="8" y1="12" x2="16" y2="12"/></svg>
    Agregar Residuo
  </button>
  <button class="tab" data-tab="pictograma">
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><circle cx="6" cy="12" r="2"/><circle cx="12" cy="12" r="2"/><circle cx="18" cy="12" r="2"/><circle cx="12" cy="6" r="2"/><circle cx="12" cy="18" r="2"/></svg>
    Pictograma
